# Agent wallet private key (must be set as verifier for target projects)
AGENT_PRIVATE_KEY=0x...

# Claude API key for evidence analysis
ANTHROPIC_API_KEY=sk-ant-...

# Storacha credentials (for persistent agent memory)
STORACHA_KEY=...
STORACHA_PROOF=...

# Filecoin credentials (for verification reports + execution logs)
FILECOIN_PRIVATE_KEY=0x...

# Unichain Sepolia RPC (optional, defaults to public RPC)
UNICHAIN_RPC_URL=https://sepolia.unichain.org

# AgentRegistry on Filecoin Calibration (optional, enables onchain reputation)
AGENT_REGISTRY_ADDRESS=0x...

# Dashboard port (optional, defaults to 3456)
DASHBOARD_PORT=3456
